---
import "../styles/global.css";
import AuthButton from "../components/AuthButton";
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | tsundoku-tools</title>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <header class="bg-white border-b border-gray-200 px-4 sm:px-6 py-3 sm:py-4">
      <nav class="max-w-5xl mx-auto flex flex-wrap items-center gap-x-6 gap-y-2">
        <a href="/" class="order-1 font-bold text-lg whitespace-nowrap">積読ツール</a>
        <div class="order-2 ml-auto">
          <AuthButton client:only="react" />
        </div>
        <div class="order-3 sm:order-2 w-full sm:w-auto flex items-center gap-6">
          <a href="/wishlists" class="text-sm text-gray-600 hover:text-gray-900 whitespace-nowrap">ウィッシュリスト</a>
          <a href="/products" class="text-sm text-gray-600 hover:text-gray-900 whitespace-nowrap">商品</a>
        </div>
      </nav>
    </header>
    <main class="max-w-5xl mx-auto px-6 py-8">
      <slot />
    </main>
  </body>
</html>
