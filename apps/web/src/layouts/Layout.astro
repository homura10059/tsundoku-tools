---
import "../styles/global.css";
import AuthButton from "../components/AuthButton";
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | tsundoku-tools</title>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <header class="bg-white border-b border-gray-200 px-6 py-4">
      <nav class="max-w-5xl mx-auto flex items-center gap-6">
        <a href="/" class="font-bold text-lg">積読ツール</a>
        <a href="/wishlists" class="text-sm text-gray-600 hover:text-gray-900">ウィッシュリスト</a>
        <a href="/products" class="text-sm text-gray-600 hover:text-gray-900">商品</a>
        <AuthButton client:only="react" />
      </nav>
    </header>
    <main class="max-w-5xl mx-auto px-6 py-8">
      <slot />
    </main>
  </body>
</html>
