{
  "name": "tsundoku-tools",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "ci:biome": "biome ci .",
    "pre-push": "pnpm run ci:biome && pnpm run type-check",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "simple-git-hooks": "^2.11.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "simple-git-hooks": {
    "pre-push": "pnpm run pre-push"
  },
  "packageManager": "pnpm@9.15.0"
}
