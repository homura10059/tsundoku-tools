{
  "name": "@tsundoku-tools/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply tsundoku-tools --local",
    "db:migrate:remote": "wrangler d1 migrations apply tsundoku-tools --remote"
  },
  "dependencies": {
    "@tsundoku-tools/shared": "workspace:*",
    "drizzle-orm": "^0.38.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  }
}
