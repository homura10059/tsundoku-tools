# Discord webhook URL for price change notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Notification thresholds
NOTIFY_MIN_PRICE_DROP_PCT=5
NOTIFY_MIN_POINT_CHANGE=50
NOTIFY_COOLDOWN_HOURS=6

# Web app API URL (Cloudflare Workers URL after deploy)
PUBLIC_API_URL=http://localhost:8787

# Cloudflare account (used by wrangler, not committed)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
